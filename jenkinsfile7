pipeline {
    agent any

    stages {

        stage('Checkout-SCM') {
            steps {
                cleanWs()
                git branch: 'main',
                    credentialsId: 'root'
                    url: 'https://github.com/ThomasDufour78/b3depotgithub.git'
            }
        }

        stage('Build-image-apache') {
            steps {
                sh '''
                docker build -t mon-apache2 .
                '''
            }
        }

        stage('Create-conteneur') {
            steps {
                sh '''
                docker stop contapache01 || true
                docker rm contapache01 || true

                docker run -d \
                    --name contapache01 \
                    --hostname contapache01 \
                    -v $(pwd)/volumecontapache01:/var/www/html \
                    --network macvlan192 \
                    --ip 192.168.1.20 \
                    mon-apache2

                docker ps
                '''
            }
        }

        stage('Init-Apache') {
            steps {
                sh '''
                docker exec contapache01 service ssh start
                docker exec contapache01 service apache2 start
                docker exec contapache01 service apache2 status
                '''
            }
        }

        stage('Copy-site') {
            steps {
                sh '''
                cp -r mysite volumecontapache01
                ls volumecontapache01
                '''
            }
        }

    }
}
